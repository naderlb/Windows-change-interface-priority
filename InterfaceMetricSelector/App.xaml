<Application x:Class="InterfaceMetricSelector.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:InterfaceMetricSelector"
             xmlns:conv="clr-namespace:InterfaceMetricSelector.Converters"
             xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             StartupUri="MainWindow.xaml"
             Startup="OnStartup"
             DispatcherUnhandledException="OnDispatcherUnhandled">
    <Application.Resources>
        <controls:BooleanToVisibilityConverter x:Key="BoolVis"/>
        <local:NullToVisibilityConverter x:Key="NullVis"/>
        <SolidColorBrush x:Key="BgDeep" Color="#0F1117"/>
        <SolidColorBrush x:Key="BgPanel" Color="#161A22"/>
        <SolidColorBrush x:Key="BgCard" Color="#1E232E"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3140"/>
        <SolidColorBrush x:Key="Accent" Color="#4D9FFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F3F8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8B93A8"/>
        <SolidColorBrush x:Key="OkGreen" Color="#3DDC97"/>
        <SolidColorBrush x:Key="WarnAmber" Color="#FFB84D"/>
        <conv:BoolToBrushConverter x:Key="ActiveFg"
                                   TrueBrush="{StaticResource OkGreen}"
                                   FalseBrush="{StaticResource TextMuted}"/>
        <!-- Default light text so dark backgrounds never inherit system black foreground -->
        <Style TargetType="Window">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="LabelMuted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#2A3140"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style x:Key="BtnMini" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style x:Key="DgCellWrap" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DgCellMuted" TargetType="TextBlock" BasedOn="{StaticResource DgCellWrap}">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style x:Key="DgCellTooltip" TargetType="TextBlock" BasedOn="{StaticResource DgCellWrap}">
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="RowBackground" Value="#1E232E"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1F2A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="RowHeight" Value="30"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252B36"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3350"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
